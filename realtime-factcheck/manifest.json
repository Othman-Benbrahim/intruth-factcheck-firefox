{
  "manifest_version": 4,
  "name": "InTruth",
  "version": "1.5.0",
  "description": "Extension Firefox de fact-checking en temps réel à partir de la transcription audio",
  "browser_specific_settings": {
    "gecko": {
      "id": "intruth@othmanbenbrahim.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "websiteContent",
          "authenticationInfo"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://api.mistral.ai/*",
    "https://api.deepseek.com/*",
    "https://api.x.ai/*",
    "https://api.together.xyz/*",
    "https://api.fireworks.ai/*",
    "https://api.perplexity.ai/*",
    "https://google.serper.dev/*",
    "https://factchecktools.googleapis.com/*",
    "https://*.wikipedia.org/*",
    "https://www.wikidata.org/*",
    "https://api.gdeltproject.org/*",
    "https://nominatim.openstreetmap.org/*",
    "https://www.ebi.ac.uk/*",
    "https://api.openalex.org/*",
    "https://api.crossref.org/*",
    "https://api.worldbank.org/*",
    "https://api.deepgram.com/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "scripts": [
      "src/background/service-worker.js"
    ]
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://www.twitch.tv/*",
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.facebook.com/*",
        "https://web.facebook.com/*",
        "https://rumble.com/*",
        "https://kick.com/*",
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*",
        "https://bsky.app/*",
        "https://odysee.com/*",
        "https://www.dailymotion.com/*"
      ],
      "js": [
        "src/content/lexical-features.js",
        "src/content/session-export.js",
        "src/content/overlay.js",
        "src/content/capture.js"
      ],
      "css": [
        "src/content/overlay.css"
      ]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}